# Copy to .env and fill in real values. Never commit the real .env.
#
# --- Required everywhere (local dev too) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
JWT_SECRET=

# --- Production-only (leave unset for local dev — safe defaults kick in) ---
# Postgres superuser (owns the Airflow metadata DB) — MUST change before
# exposing this host to the internet; default is "airflow".
POSTGRES_PASSWORD=
# App DB user "crawler" (owns crawl_platform) — MUST change before exposing
# this host to the internet; default is "crawler". Only takes effect on the
# FIRST start of an empty postgres-data volume (see scripts/init-postgres.sh)
# — changing it later requires ALTER USER crawler PASSWORD '...' manually.
APP_DB_PASSWORD=
# Airflow web UI (:8081) admin login — MUST change before exposing this host
# to the internet; default is "admin". Also only takes effect the first time
# airflow-init runs against a fresh Airflow metadata DB.
AIRFLOW_ADMIN_PASSWORD=
# Comma-separated list of origins the API will accept browser requests from.
# Set to wherever the frontend is actually served, e.g. http://<VPS_IP>:5173
API_CORS_ORIGINS=
# Baked into the frontend's JS bundle at build time (docker compose build
# frontend) — must match where the `api` service is reachable from a
# browser, e.g. http://<VPS_IP>:8083
VITE_API_BASE_URL=

# --- Remote fb-celery-worker (2nd machine) ---
# Leave unset for a normal single-machine setup — postgres/redis/rabbitmq
# stay loopback-only, unreachable outside this host. Set to THIS host's
# Tailscale IP (100.x.x.x) only if a second machine is running its own
# fb-celery-worker via docker-compose.worker.yml and needs to reach these
# over the tailnet. NEVER set to "0.0.0.0" or a public IP — see
# docs/fb-worker-remote.md.
LAN_BIND_IP=

# --- FB proxy pool (fb-celery-worker) ---
# Leave all unset to crawl direct (no proxy) — safe default, matches
# today's behavior. Only takes effect on fb-celery-worker (the container
# that actually opens the Playwright session), not Airflow.
#
# Option A — several authenticated proxies (e.g. 4G/mobile ports, each with
# its own IP-rotation API), round-robin. REQUIRED if FB_CELERY_CONCURRENCY
# > 1 — with only one proxy, two batches running at once both call its
# reset URL and can clobber each other's still-in-flight session on the
# same port. Numbered from 1, no gaps:
# FB_PROXY_SERVER_1=
# FB_PROXY_USER_1=
# FB_PROXY_PASS_1=
# FB_PROXY_RESET_URL_1=
# FB_PROXY_SERVER_2=
# FB_PROXY_USER_2=
# FB_PROXY_PASS_2=
# FB_PROXY_RESET_URL_2=
#
# Option B — single authenticated proxy — only safe with concurrency=1:
FB_PROXY_SERVER=
FB_PROXY_USER=
FB_PROXY_PASS=
# GET endpoint that rotates the IP behind FB_PROXY_SERVER — called once per
# batch, before the browser session opens for that batch.
FB_PROXY_RESET_URL=
#
# Option C — several unauthenticated proxies, round-robin, no IP reset:
# FB_PROXY_SERVERS=http://proxy1:8080,http://proxy2:8080

# --- Daily report email (dag_report_email) ---
# SMTP relay used to send the daily report .xlsx to each org's configured
# recipient (Settings page). Leave unset to disable — the DAG just logs a
# warning and skips every org until these are set.
# Gmail: use an App Password (myaccount.google.com/apppasswords, requires
# 2FA on the account), NOT the regular account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
