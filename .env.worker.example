# For the SECOND machine running docker-compose.worker.yml only — copy to
# .env next to docker-compose.worker.yml on that machine. See
# docs/fb-worker-remote.md for the full setup runbook.

# Tailscale IP (100.x.x.x) of the hub machine — the one running the main
# docker-compose.yml with LAN_BIND_IP set to this same IP. Never a public IP.
HUB_HOST=

# Must match APP_DB_PASSWORD on the hub exactly (same Postgres user).
APP_DB_PASSWORD=

# Optional — defaults to 4, same as the hub's fb-celery-worker.
FB_CELERY_CONCURRENCY=

# Deliberately no FB_PROXY_* variables here — see docker-compose.worker.yml's
# comment on fb-celery-worker for why. Leave this machine on a direct
# connection (its own IP).
